---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<title>C Tutor - AI Hint POC</title>
		<style>
			body { font-family: system-ui, sans-serif; background: #13151a; color: white; padding: 2rem; }
			.container { display: grid; grid-template-columns: 1fr 350px; gap: 2rem; max-width: 1200px; margin: 0 auto; }
			header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem; border-bottom: 1px solid #333; padding-bottom: 1rem; }
			
			.code-box { background: #1e1e1e; padding: 1rem; border-radius: 8px; border: 1px solid #444; position: relative; }
			textarea { width: 100%; height: 400px; background: transparent; color: #d4d4d4; border: none; font-family: 'Fira Code', monospace; font-size: 14px; resize: none; outline: none; }
			
			.hint-pane { background: #23262d; padding: 1.5rem; border-radius: 8px; border: 1px solid #3b82f6; height: fit-content; min-height: 200px; }
			.hint-text { line-height: 1.6; color: #e0e0e0; white-space: pre-wrap; }
			.hint-text:empty::before { content: "Click 'Get Hint' to see AI suggestions..."; color: #666; font-style: italic; }
			
			button { background: #3b82f6; color: white; border: none; padding: 0.8rem 1.5rem; border-radius: 4px; cursor: pointer; font-weight: bold; transition: opacity 0.2s; }
			button:disabled { opacity: 0.5; cursor: not-allowed; }
			.status { font-size: 0.8rem; margin-top: 1rem; color: #999; }
		</style>
	</head>
	<body>
		<header>
			<h1>C Programming Tutor</h1>
			<button id="hint-btn">Get a Hint</button>
		</header>

		<main class="container">
			<section class="code-box">
				<textarea id="c-code" spellcheck="false">
/* * Task: Reverse the string in-place.
 * Bug: This code has index out-of-bounds 
 * and swap logic errors.
 */
#include <stdio.h>
#include <string.h>

void reverse_string(char *str) {
    int len = strlen(str);
    for (int i = 0; i <= len; i++) {
        char temp = str[i];
        str[i] = str[len - i]; 
        str[len - i] = temp;
    }
}

int main() {
    char text[] = "Hello";
    reverse_string(text);
    printf("Reversed: %s\n", text);
    return 0;
}
				</textarea>
			</section>

			<aside class="hint-pane">
				<h3>💡 Tutor Hint</h3>
				<div id="hint-display" class="hint-text"></div>
				<div id="status-msg" class="status"></div>
			</aside>
		</main>

		<script>
			const hintBtn = document.getElementById('hint-btn');
			const hintDisplay = document.getElementById('hint-display');
			const statusMsg = document.getElementById('status-msg');
			const codeArea = document.getElementById('c-code');

			hintBtn.addEventListener('click', async () => {
				// reset ui
				hintDisplay.textContent = "";
				hintBtn.disabled = true;
				statusMsg.textContent = "AI is thinking...";

				try {
					// call proxy
					const response = await fetch('https://sisa.lunaui.cc/api/v1/getHintStream', {
						method: 'POST',
						headers: { 'Content-Type': 'application/json' },
						body: JSON.stringify({ 
							code: codeArea.value,
							problemStatement: "Reverse a string in-place without using extra memory."
						}),
					});

					if (!response.ok) throw new Error("Server error");

					// handle stream
					const reader = response.body.getReader();
					const decoder = new TextDecoder();

					while (true) {
						const { value, done } = await reader.read();
						if (done) break;

						const chunk = decoder.decode(value);
						const lines = chunk.split('\n');

						for (const line of lines) {
							if (line.startsWith('data: ')) {
								const dataStr = line.replace('data: ', '');
								if (dataStr === '[DONE]') break;
								
								try {
									const parsed = JSON.parse(dataStr);
									if (parsed.text) {
										hintDisplay.textContent += parsed.text;
									}
								} catch (e) { /* partial chunk */ }
							}
						}
					}
					statusMsg.textContent = "Hint complete.";
				} catch (err) {
					hintDisplay.textContent = "Error: Could not reach the tutor. Make sure your backend is running!";
					statusMsg.textContent = "";
				} finally {
					hintBtn.disabled = false;
				}
			});
		</script>
	</body>
</html>